{
  "name": "desktop-client",
  "private": true,
  "version": "0.0.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && sed -i '' 's/crossorigin//g' dist/index.html && electron-builder",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.cloudpersonal.sync",
    "productName": "Cloud Sync",
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png",
      "artifactName": "CloudSync-mac.${ext}"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.png",
      "artifactName": "CloudSync-win.${ext}"
    },
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-wasm": "^4.22.0",
    "@vladmandic/face-api": "^1.7.15",
    "better-sqlite3": "^12.11.1",
    "blurhash": "^2.0.5",
    "cors": "^2.8.6",
    "d3-force": "^3.0.0",
    "dotenv": "^17.4.2",
    "exifr": "^7.1.3",
    "express": "^5.2.1",
    "lucide-react": "^1.24.0",
    "multer": "^2.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-force-graph-2d": "^1.29.1",
    "react-qr-code": "^2.2.0",
    "sharp": "^0.34.5",
    "translate": "^3.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.4",
    "axios": "^1.18.1",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.4",
    "cross-env": "^10.1.0",
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3",
    "form-data": "^4.0.6",
    "oxlint": "^1.71.0",
    "postcss": "^8.5.19",
    "tailwindcss": "^4.3.3",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-electron": "^1.1.0",
    "vite-plugin-electron-renderer": "^1.0.0",
    "wait-on": "^9.0.10"
  }
}
